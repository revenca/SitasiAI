# ─────────────────────────────────────────────────────────────────────────────
# Contoh environment variables untuk sistem citation recommendation.
# Cara pakai:
#   1. Copy file ini menjadi ".env"   →  Copy-Item .env.example .env
#   2. Isi nilai API key di bawah dengan key milikmu
#   3. Jangan commit file ".env" ke git (sudah masuk .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# OpenRouter API key — dipakai untuk SEMUA LLM call:
#   - pipeline.py  : generasi HyDE + CoT  → GPT-4o-mini
#   - evaluate.py  : judge RAGAS          → Claude Sonnet 4.5 (beda vendor, hindari self-bias)
# Dapatkan di: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Opsional) Override model generator & judge.
# GEN_MODEL=openai/gpt-4o-mini
# JUDGE_MODEL=anthropic/claude-sonnet-4.5
